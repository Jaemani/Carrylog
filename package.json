{
  "name": "carrylog",
  "version": "0.1.0-beta.4",
  "description": "Repository-owned, reviewable project context for AI coding agents.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "bin": {
    "carrylog": "dist/cli.js"
  },
  "files": [
    "dist",
    "schemas",
    "docs",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "README.md",
    "ROADMAP.md",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "tag": "beta",
    "provenance": true
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "test": "npm run build && node --test --test-concurrency=1",
    "test:coverage": "npm run build && node --test --test-concurrency=1 --experimental-test-coverage --test-coverage-include=dist/**/*.js --test-coverage-exclude=dist/cli.js --test-coverage-lines=90 --test-coverage-functions=90 --test-coverage-branches=85",
    "test:package": "npm run build && node scripts/package-smoke.mjs",
    "test:package:publish": "npm run build && node scripts/package-smoke.mjs --publish-dry-run",
    "quality": "npm run format:check && npm run check && npm run test:coverage",
    "pack:check": "npm run build && node scripts/package-dry-run.mjs",
    "release:client:check": "node scripts/check-release-client.mjs 11.18.0",
    "release:publish": "node scripts/publish-release-artifact.mjs",
    "release:verify": "npm run quality && node dist/cli.js sync --check && node dist/cli.js validate --json && npm run pack:check && node scripts/build-release-artifact.mjs && node scripts/package-smoke.mjs --release --publish-dry-run && npm audit --omit=dev",
    "prepack": "npm run build"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/node": "^22.18.0",
    "ajv": "^8.20.0",
    "typescript": "^5.9.2"
  },
  "keywords": [
    "ai-agents",
    "codex",
    "claude-code",
    "context-governance",
    "developer-tools",
    "handoff",
    "project-context",
    "project-memory"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jaemani/Carrylog.git"
  },
  "bugs": {
    "url": "https://github.com/Jaemani/Carrylog/issues"
  },
  "homepage": "https://github.com/Jaemani/Carrylog#readme"
}
